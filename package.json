{
  "name": "dukanchi-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "embed:backfill": "tsx scripts/backfillEmbeddings.ts",
    "seed:test": "tsx scripts/seedTestData.ts && tsx scripts/backfillEmbeddings.ts",
    "dev": "tsx server.ts",
    "dev:web": "vite",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:mobile": "VITE_API_URL=https://dukanchi.com vite build",
    "sync:android": "npm run build:mobile && npx cap sync android",
    "open:android": "npx cap open android",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "npm run typecheck:web && npm run typecheck:server && npm run typecheck:worker",
    "typecheck:web": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings=9999",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "start": "tsx server.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^1.50.1",
    "@prisma/client": "^5.22.0",
    "@react-google-maps/api": "^2.20.8",
    "@react-oauth/google": "^0.13.4",
    "@sentry/node": "^10.59.0",
    "@sentry/profiling-node": "^10.59.0",
    "@sentry/react": "^10.59.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.9.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "ioredis": "~5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "multer": "^2.2.0",
    "multer-s3": "^3.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "posthog-js": "^1.391.2",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "redis": "^5.12.1",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "vite": "^6.2.0",
    "web-push": "^3.6.7",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "canvas": "^3.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "terser": "^5.48.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
