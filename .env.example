# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres (Singapore region recommended for India).
# connection_limit=10 and pool_timeout=20 are Neon's recommended values for
# medium-traffic apps. Adjust connection_limit to match your PgBouncer pool size
# if using Neon's connection pooling endpoint.
DATABASE_URL="postgresql://USER:PASSWORD@host.neon.tech/neondb?sslmode=require&connection_limit=10&pool_timeout=20"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-minimum-32-chars"

# ─── Admin account seeding ────────────────────────────────────────────────────
# Both must be set or the admin account will not be created on startup
ADMIN_PHONE=""
ADMIN_PASSWORD=""

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
VITE_API_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── CORS (comma-separated origins) ──────────────────────────────────────────
# Note: capacitor://localhost (iOS) and http://localhost (Android) are allowed
# automatically by the server — do NOT add them here, they are hardcoded.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Cloudflare R2 / AWS S3 ──────────────────────────────────────────────────
# Leave blank to use local /uploads/ directory (dev only)
S3_BUCKET_NAME=""
AWS_REGION="auto"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
R2_PUBLIC_URL=""

# ─── Google APIs ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
VITE_GOOGLE_MAPS_API_KEY=""

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# ─── Sentry (optional — error monitoring) ────────────────────────────────────
SENTRY_DSN=""

# ─── Push Notifications (optional) ───────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_MAILTO=""
