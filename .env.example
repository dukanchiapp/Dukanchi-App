# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres (Singapore region recommended for India).
# connection_limit=10 and pool_timeout=20 are Neon's recommended values for
# medium-traffic apps. Adjust connection_limit to match your PgBouncer pool size
# if using Neon's connection pooling endpoint.
DATABASE_URL="postgresql://USER:PASSWORD@host.neon.tech/neondb?sslmode=require&connection_limit=10&pool_timeout=20"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-minimum-32-chars"
# Refresh token signing secret — Day 5 / Session 92.
# MUST be distinct from JWT_SECRET. In dev, a fallback is provided in code
# (server still boots); in production, this MUST be set or boot hard-fails.
# Generate: openssl rand -base64 48
JWT_REFRESH_SECRET=""
# Password hash cost factor. 12 is 2026 production-ready default. Min 10, max 14.
BCRYPT_ROUNDS=12

# ─── Admin account seeding ────────────────────────────────────────────────────
# Both must be set or the admin account will not be created on startup
ADMIN_PHONE=""
ADMIN_PASSWORD=""

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
VITE_API_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── CORS (comma-separated origins) ──────────────────────────────────────────
# Note: capacitor://localhost (iOS) and http://localhost (Android) are allowed
# automatically by the server — do NOT add them here, they are hardcoded.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Cloudflare R2 / AWS S3 ──────────────────────────────────────────────────
# Leave blank to use local /uploads/ directory (dev only)
S3_BUCKET_NAME=""
AWS_REGION="auto"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
R2_PUBLIC_URL=""

# ─── Google APIs ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
VITE_GOOGLE_MAPS_API_KEY=""

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# ─── Sentry (optional — error monitoring) ────────────────────────────────────
# Backend Sentry — Node SDK in src/lib/sentry.ts. Gracefully disabled if unset.
SENTRY_DSN=""

# Frontend Sentry — Browser SDK in src/lib/sentry-frontend.ts.
# Recommended: separate Sentry project from backend so quotas are tracked
# independently. Gracefully disabled if unset.
VITE_SENTRY_DSN=""

# For source-map upload at build time (so Sentry stack traces are readable).
# Generate at: Sentry dashboard → Settings → Auth Tokens → Create New Token
# Required scopes: project:releases (write), project:write
# If unset, frontend build succeeds with a warning; events arrive but stack
# traces stay minified until source maps are uploaded.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ─── PostHog (optional — product analytics) ──────────────────────────────────
# EU instance default (DPDP-friendly, closer to India). Override host for US.
# Gracefully disabled if VITE_POSTHOG_KEY unset.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://eu.i.posthog.com"

# ─── Push Notifications (optional) ───────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_MAILTO=""
